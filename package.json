{
  "name": "kadrix.fr",
  "version": "0.1.0",
  "private": true,
  "repository": "https://github.com/zteeed/kadrix.fr",
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
